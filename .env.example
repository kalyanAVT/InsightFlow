# Qdrant Cloud (free tier)
QDRANT_URL= paste_QDRANT_Endpoint_url
QDRANT_API_KEY= paste_QDRANT_API_KEY
# Search
TAVILY_API_KEY= Tavily_api_key

# LLM (Groq default, OpenAI fallback)
GROQ_API_KEY= gorq_api_key
#OPENAI_API_KEY= open_ai_api_key

# Model config
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# Redis (local or cloud)
REDIS_URL=redis://default:password@EndPoint.redis.io:port

# Quality thresholds
CITATION_THRESHOLD=0.30 #(changed form .50 to .30 for testing)
QUALITY_THRESHOLD=0.75
MAX_RETRIES=2

# HF
HF_HUB_DISABLE_SYMLINKS_WARNING=1
